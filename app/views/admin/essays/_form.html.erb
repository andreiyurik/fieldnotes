<%# locals: (essay:) %>
<%= admin_error_list(essay) %>

<%= form_with model: [:admin, essay] do |f| %>
  <%= admin_card do %>
    <div class="mb-4">
      <%= f.label :title, class: admin_label_class %>
      <%= f.text_field :title, class: admin_input_class %>
    </div>
    <div class="mb-4">
      <%= f.label :excerpt, class: admin_label_class %>
      <%= f.text_area :excerpt, rows: 3, class: admin_input_class %>
    </div>
    <div class="mb-4">
      <%= f.label :status, class: admin_label_class %>
      <%= f.select :status, Essay::STATUSES, {}, class: admin_input_class %>
    </div>
    <div class="mb-4">
      <%= f.label :published_at, class: admin_label_class %>
      <%= f.datetime_local_field :published_at, class: admin_input_class %>
      <p class="<%= admin_hint_class %>">Leave blank — will be set automatically when published.</p>
    </div>
    <div class="mb-4 last:mb-0">
      <%= f.label :cover, class: admin_label_class %>
      <%= f.file_field :cover, class: "text-sm text-[#57534E] cursor-pointer" %>
    </div>
  <% end %>

  <%= admin_card(title: "Content") do %>
    <%= f.rich_text_area :content %>
  <% end %>

  <div class="flex items-center gap-3">
    <% if essay.published? %>
      <%= f.submit "Save", class: btn_primary_class %>
    <% else %>
      <%= f.submit "Save Draft", class: btn_secondary_class %>
      <%= f.submit "Publish", class: btn_primary_class %>
    <% end %>
  </div>
<% end %>
