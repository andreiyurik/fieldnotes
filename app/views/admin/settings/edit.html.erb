<% content_for :title, "Settings" %>

<%= admin_toolbar(title: "Settings") %>
<%= admin_error_list(@setting) %>

<%= form_with model: @setting, url: admin_settings_path, method: :patch do |f| %>
  <%= admin_card(title: "Watermark") do %>
    <div class="mb-4">
      <div class="flex items-center gap-3">
        <%= f.check_box :watermark_enabled, class: "w-4 h-4 accent-accent" %>
        <%= f.label :watermark_enabled, "Enable watermark on Field photos", class: "text-sm text-[#1C1917] cursor-pointer" %>
      </div>
    </div>
    <div class="mb-4">
      <%= f.label :watermark, "Watermark image (PNG with transparency)", class: admin_label_class %>
      <%= f.file_field :watermark, accept: "image/png", class: "text-sm text-[#57534E] cursor-pointer" %>
      <% if @setting.watermark.attached? %>
        <p class="<%= admin_hint_class %>">Current: <%= @setting.watermark.filename %> — upload a new file to replace it</p>
        <div class="mt-2 p-2 bg-[#888] rounded inline-block">
          <%= image_tag @setting.watermark, alt: "Watermark preview", class: "max-h-[60px]" %>
        </div>
      <% end %>
    </div>
    <div class="mb-4">
      <%= f.label :watermark_position, "Position", class: admin_label_class %>
      <%= f.select :watermark_position, [["Bottom right", "bottom_right"], ["Bottom left", "bottom_left"], ["Top right", "top_right"], ["Top left", "top_left"]], {}, class: admin_input_class %>
    </div>
    <div class="mb-0">
      <%= f.label :watermark_opacity, "Opacity (10–80%)", class: admin_label_class %>
      <%= f.number_field :watermark_opacity, min: 10, max: 80, step: 5, class: admin_input_class %>
    </div>
  <% end %>

  <%= f.submit "Save settings", class: btn_primary_class %>
<% end %>

<hr class="border-none border-t border-[#E8E3DC] my-8">

<%= admin_card(title: "Regenerate watermarks") do %>
  <p class="<%= admin_hint_class %>">Apply current watermark settings to all Field photos. Runs in background.</p>
  <%= button_to "Regenerate all watermarks",
        regenerate_watermarks_admin_settings_path,
        method: :post,
        class: "#{btn_secondary_class} mt-3",
        data: { turbo_confirm: "This will re-process all Field photos in the background. Continue?" } %>
<% end %>
