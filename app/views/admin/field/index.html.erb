<% content_for :title, "Field Series" %>

<%= admin_toolbar(title: "Field Series") do %>
  <%= link_to "New Series", new_admin_field_path, class: btn_primary_class %>
<% end %>

<% if @series.any? %>
  <div class="bg-white rounded-xl overflow-hidden shadow-sm">
    <table class="w-full border-collapse">
      <thead>
        <tr>
          <th class="<%= admin_table_th_class %>">Title</th>
          <th class="<%= admin_table_th_class %>">Kind</th>
          <th class="<%= admin_table_th_class %>">Location</th>
          <th class="<%= admin_table_th_class %>">Date</th>
          <th class="<%= admin_table_th_class %>"></th>
        </tr>
      </thead>
      <tbody>
        <% @series.each do |s| %>
          <tr class="hover:bg-[#FAFAF9] transition">
            <td class="<%= admin_table_td_class %>">
              <%= link_to s.title, admin_field_path(s), class: "text-accent hover:text-[#D4631E] font-medium" %>
            </td>
            <td class="<%= admin_table_td_class %> text-[#78716C]"><%= s.kind %></td>
            <td class="<%= admin_table_td_class %> text-[#78716C]"><%= s.location %></td>
            <td class="<%= admin_table_td_class %> text-[#78716C]"><%= s.taken_on&.strftime("%b %d, %Y") %></td>
            <td class="<%= admin_table_td_class %> text-right">
              <%= link_to "Edit", edit_admin_field_path(s),
                    class: "text-sm text-[#57534E] hover:text-[#1C1917] px-2 py-1 rounded hover:bg-[#F0EDE8] transition" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-center py-12 text-[#78716C] text-sm">
    No field series yet. <%= link_to "Create your first one", new_admin_field_path, class: "text-accent" %>
  </p>
<% end %>
