<%# locals: (series:) %>
<%= admin_error_list(series) %>

<% url = series.new_record? ? admin_field_index_path : admin_field_path(series) %>
<%= form_with model: [:admin, series], url: url do |f| %>
  <%= admin_card do %>
    <div class="mb-4">
      <%= f.label :cover, class: admin_label_class %>
      <%= f.file_field :cover, accept: "image/*", class: "text-sm text-[#57534E] cursor-pointer" %>
      <% if series.cover.attached? %>
        <div class="mt-2">
          <%= image_tag series.cover.variant(:thumb), class: "w-40 h-30 object-cover rounded-md" %>
        </div>
      <% end %>
    </div>
    <div class="mb-4">
      <%= f.label :title, class: admin_label_class %>
      <%= f.text_field :title, class: admin_input_class %>
    </div>
    <div class="mb-4">
      <%= f.label :description, class: admin_label_class %>
      <%= f.text_area :description, rows: 3, class: admin_input_class %>
    </div>
    <div class="mb-4">
      <%= f.label :kind, class: admin_label_class %>
      <%= f.select :kind, FieldSeries::KINDS, {}, class: admin_input_class %>
    </div>
    <div class="mb-4">
      <%= f.label :location, class: admin_label_class %>
      <%= f.text_field :location, class: admin_input_class %>
    </div>
    <div class="mb-4 last:mb-0">
      <%= f.label :taken_on, class: admin_label_class %>
      <%= f.date_field :taken_on, class: admin_input_class %>
    </div>
  <% end %>

  <%= f.submit "Save", class: btn_primary_class %>
<% end %>
