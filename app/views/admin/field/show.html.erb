<% content_for :title, @series.title %>

<%= admin_toolbar(title: @series.title) do %>
  <%= link_to "Edit series", edit_admin_field_path(@series), class: btn_secondary_class %>
  <%= link_to "View on site", field_path(@series.slug), target: "_blank", class: btn_secondary_class %>
<% end %>

<h2 class="text-lg font-semibold mb-4 text-[#1C1917]">Items (<%= @series.field_items.count %>)</h2>

<% @series.field_items.ordered.each do |item| %>
  <div class="bg-white rounded-xl shadow-sm p-4 mb-3 flex items-start justify-between gap-4">
    <div class="flex items-start gap-4 flex-1 min-w-0">
      <% if item.photo.attached? %>
        <div class="flex-shrink-0">
          <%= image_tag item.photo.variant(:thumb), alt: item.caption.to_s,
                class: "w-[120px] h-[90px] object-cover rounded-md" %>
        </div>
      <% end %>
      <div class="flex-1 min-w-0">
        <%= badge(item.kind) %>
        <% if item.caption.present? %>
          <p class="text-sm text-[#1C1917] mt-1.5"><%= item.caption %></p>
        <% end %>
        <% if item.youtube_url.present? %>
          <p class="text-xs text-[#78716C] mt-1"><%= item.youtube_url %></p>
        <% end %>
        <p class="text-xs text-[#78716C] mt-1">Position: <%= item.position %></p>
      </div>
    </div>
    <div class="flex-shrink-0">
      <%= button_to "Delete", admin_field_field_item_path(@series, item), method: :delete,
            class: btn_danger_class,
            form: { data: { turbo_confirm: "Delete this item?" } } %>
    </div>
  </div>
<% end %>

<div class="bg-white rounded-xl shadow-sm p-6 mt-6">
  <h2 class="text-lg font-semibold mb-4 text-[#1C1917]">Add item</h2>
  <%= form_with model: [@series, FieldItem.new], url: admin_field_field_items_path(@series) do |f| %>
    <div class="mb-4">
      <%= f.label :kind, class: admin_label_class %>
      <%= f.select :kind, FieldItem::KINDS, {}, class: admin_input_class %>
    </div>
    <div class="mb-4">
      <%= f.label :photo, class: admin_label_class %>
      <%= f.file_field :photo, accept: "image/*", class: "text-sm text-[#57534E] cursor-pointer" %>
    </div>
    <div class="mb-4">
      <%= f.label :caption, class: admin_label_class %>
      <%= f.text_field :caption, class: admin_input_class %>
    </div>
    <div class="mb-4">
      <%= f.label :youtube_url, "YouTube URL (for videos)", class: admin_label_class %>
      <%= f.url_field :youtube_url, class: admin_input_class %>
    </div>
    <div class="mb-4">
      <%= f.label :position, class: admin_label_class %>
      <%= f.number_field :position, value: (@series.field_items.maximum(:position).to_i + 1), class: admin_input_class %>
    </div>
    <%= f.submit "Add item", class: btn_primary_class %>
  <% end %>
</div>
