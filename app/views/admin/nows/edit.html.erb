<% content_for :title, "Now" %>

<%= admin_toolbar(title: "Now") do %>
  <%= link_to "View on site", now_path, target: "_blank", class: btn_secondary_class %>
<% end %>

<%= admin_card do %>
  <%= form_with model: @now_entry, url: admin_now_path, method: :patch do |f| %>
    <div class="mb-4">
      <%= f.rich_text_area :body %>
      <p class="<%= admin_hint_class %>">Each update creates a new entry. Previous versions are kept as history.</p>
    </div>
    <%= f.submit "Update", class: btn_primary_class %>
  <% end %>
<% end %>

<% if @previous_entries.any? %>
  <h2 class="text-lg font-semibold mb-3 text-[#1C1917]">Previous entries</h2>
  <% @previous_entries.each do |entry| %>
    <div class="bg-white rounded-xl shadow-sm px-4 py-3 mb-2">
      <p class="text-xs text-[#78716C]"><%= entry.published_at.strftime("%b %d, %Y at %H:%M") %></p>
    </div>
  <% end %>
<% end %>
