<% content_for :title, "Now" %>
<% content_for :head do %>
  <%= meta_tags(title: "Now", description: "What I'm working on right now.") %>
<% end %>

<h1 class="text-3xl font-bold tracking-tight mb-8">Now</h1>

<% if @current %>
  <div class="lexxy-content mb-4"><%= @current.body %></div>
  <p class="text-muted text-sm">
    <time datetime="<%= @current.published_at.iso8601 %>">
      Updated <%= @current.published_at.strftime("%B %d, %Y") %>
    </time>
  </p>
<% end %>

<% if @previous.any? %>
  <section class="previous-entries mt-12">
    <h2 class="text-xl font-semibold mb-4">Previous entries</h2>
    <% @previous.each do |entry| %>
      <details class="border-t border-border py-4">
        <summary class="text-muted cursor-pointer hover:text-ink transition">
          <%= entry.published_at.strftime("%B %d, %Y") %>
        </summary>
        <div class="lexxy-content mt-3"><%= entry.body %></div>
      </details>
    <% end %>
  </section>
<% end %>
