<% content_for :title, @series.title %>
<% content_for :main_class, "max-w-[90rem]" %>
<% content_for :head do %>
  <%= meta_tags(title: @series.title, description: @series.description.presence || @series.title) %>
<% end %>

<nav class="mb-6">
  <%= link_to "← Field", field_index_path, class: "text-muted hover:text-accent transition" %>
</nav>

<header class="mb-8">
  <h1 class="text-4xl font-bold mb-3"><%= @series.title %></h1>
  <div class="flex items-center gap-3 flex-wrap mb-3">
    <% if @series.location.present? %>
      <span class="text-muted">📍 <%= @series.location %></span>
      <span class="text-border">·</span>
    <% end %>
    <% if @series.taken_on.present? %>
      <time class="text-muted" datetime="<%= @series.taken_on.iso8601 %>">
        <%= @series.taken_on.strftime("%B %Y") %>
      </time>
      <span class="text-border">·</span>
    <% end %>
    <%= badge(@series.kind) %>
  </div>
  <% if @series.description.present? %>
    <p class="text-muted leading-relaxed"><%= @series.description %></p>
  <% end %>
</header>

<div class="space-y-8">
  <% @series.field_items.ordered.each_with_index do |item, index| %>
    <figure>
      <% if item.photo.attached? %>
        <div class="rounded-lg overflow-hidden">
          <%= picture_tag(
            field_item_photo(item),
            alt:     item.caption.presence || @series.title,
            sizes:   "(max-width: 768px) 100vw, (max-width: 1440px) 95vw, 1392px",
            loading: index.zero? ? "eager" : "lazy"
          ) %>
        </div>
      <% elsif item.youtube_url.present? %>
        <% if (video_id = item.youtube_video_id) %>
          <div class="rounded-lg overflow-hidden aspect-video">
            <iframe src="https://www.youtube-nocookie.com/embed/<%= video_id %>"
                    title="<%= item.caption.presence || @series.title %>"
                    class="w-full h-full"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    loading="lazy"></iframe>
          </div>
        <% end %>
      <% end %>
      <% if item.caption.present? %>
        <figcaption class="text-muted text-sm mt-2 text-center italic"><%= item.caption %></figcaption>
      <% end %>
      <%= render "shared/exif", item: item %>
    </figure>
  <% end %>
</div>
