<% content_for :title, @essay.title %>
<% content_for :main_class, "max-w-[70ch]" %>
<% content_for :head do %>
  <%= meta_tags(
    title:        @essay.title,
    description:  @essay.excerpt.presence || @essay.title,
    image:        @essay.cover.attached? ? url_for(@essay.cover) : nil,
    type:         :article,
    published_at: @essay.published_at
  ) %>
<% end %>

<article>
  <h1 class="text-4xl font-bold tracking-tight mb-4"><%= @essay.title %></h1>
  <div class="text-muted text-sm mb-10">
    <time datetime="<%= @essay.published_at.iso8601 %>">
      <%= @essay.published_at.strftime("%B %d, %Y") %>
    </time>
  </div>
  <div class="lexxy-content">
    <%= @essay.content %>
  </div>
</article>
