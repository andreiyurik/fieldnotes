<%# locals: (profile:) %>
<section class="flex items-center gap-6 mb-12 pb-8 border-b border-border">
  <div class="flex-shrink-0">
    <% if profile.avatar.attached? %>
      <%= image_tag profile.avatar, alt: profile.name, class: "w-24 h-24 rounded-full object-cover" %>
    <% else %>
      <img src="/avatar.jpg" alt="<%= profile.name %>" class="w-24 h-24 rounded-full object-cover">
    <% end %>
  </div>
  <div>
    <h2 class="text-2xl font-bold mb-1"><%= profile.name %></h2>
    <% if profile.bio.present? %>
      <div class="text-muted lexxy-content"><%= profile.bio %></div>
    <% end %>
  </div>
</section>
