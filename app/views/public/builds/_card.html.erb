<%# locals: (build:) %>
<article class="bg-surface border border-border rounded-lg p-6 flex flex-col gap-3 transition hover:border-accent hover:-translate-y-0.5">
  <div class="text-3xl leading-none"><%= build.icon_emoji %></div>
  <div class="flex-1">
    <h3 class="text-[1.0625rem] font-semibold mb-0">
      <% if build.url.present? %>
        <%= link_to build.title, build.url, class: "text-ink hover:text-accent", target: "_blank", rel: "noopener noreferrer" %>
      <% else %>
        <%= build.title %>
      <% end %>
    </h3>
    <% if build.description.present? %>
      <p class="text-muted text-[0.9375rem] leading-relaxed m-0"><%= build.description %></p>
    <% end %>
  </div>
  <%= badge(build.status) %>
</article>
