<% content_for :title, "Reading" %>
<% content_for :main_class, "max-w-[90rem]" %>
<% content_for :head do %>
  <%= meta_tags(title: "Reading", description: "Books I've read and key ideas from each.") %>
<% end %>

<h1 class="text-3xl font-bold tracking-tight mb-8">Reading</h1>

<% if @reading.any? %>
  <p class="text-muted text-sm mb-4">Currently reading</p>
  <div class="grid gap-6 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 mb-12">
    <%= render partial: "public/books/card", collection: @reading, as: :book %>
  </div>
<% end %>

<% if @books.empty? && @reading.empty? %>
  <p class="text-muted text-center py-16">No books yet.</p>
<% else %>
  <div class="grid gap-6 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
    <%= render partial: "public/books/card", collection: @books, as: :book %>
  </div>
<% end %>
