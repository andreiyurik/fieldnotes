<%# locals: (book:) %>
<%= link_to book_path(book), class: "flex flex-col gap-3 no-underline text-inherit group" do %>
  <div class="w-full aspect-[2/3] rounded-lg overflow-hidden bg-surface shadow-sm transition group-hover:-translate-y-1 group-hover:shadow-md">
    <% if book.cover_image_url.present? %>
      <img src="<%= book.cover_image_url %>" alt="<%= book.title %>" class="w-full h-full object-cover block" loading="lazy">
    <% else %>
      <%= render "public/books/placeholder", title: book.title %>
    <% end %>
  </div>
  <div class="flex flex-col gap-0.5">
    <p class="text-[0.8125rem] font-semibold text-ink leading-snug"><%= book.title %></p>
    <p class="text-xs text-muted"><%= book.author %></p>
    <% if book.rating %>
      <p class="text-[0.6875rem] text-accent tracking-widest"><%= "★" * book.rating %></p>
    <% end %>
  </div>
<% end %>
