<h1 class="text-xl font-bold text-[#1C1917] mb-6">Forgot your password?</h1>

<%= form_with url: passwords_path do |f| %>
  <div class="mb-6">
    <%= f.label :email_address, "Email", class: "block text-xs font-semibold uppercase tracking-[0.05em] text-[#57534E] mb-1.5" %>
    <%= f.email_field :email_address,
          required: true,
          autofocus: true,
          autocomplete: "username",
          placeholder: "you@example.com",
          value: params[:email_address],
          class: "w-full px-3 py-2 border border-[#D6D3D1] rounded-md text-sm text-[#1C1917] bg-white focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/15 transition" %>
  </div>
  <%= f.submit "Email reset instructions", class: "w-full px-4 py-2 bg-accent text-white rounded-md text-sm font-medium cursor-pointer border-none hover:bg-[#D4631E] transition" %>
<% end %>

<div class="mt-4 text-center text-sm text-[#78716C]">
  <%= link_to "Back to sign in", new_session_path, class: "text-accent hover:text-[#D4631E]" %>
</div>
