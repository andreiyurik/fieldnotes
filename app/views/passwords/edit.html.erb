<h1 class="text-xl font-bold text-stone-900 mb-6">Update your password</h1>

<%= form_with url: password_path(params[:token]), method: :put do |f| %>
  <div class="mb-4">
    <%= f.label :password, "New password", class: "block text-xs font-semibold uppercase tracking-[0.05em] text-stone-600 mb-1.5" %>
    <%= f.password_field :password,
          required: true,
          autocomplete: "new-password",
          placeholder: "••••••••",
          maxlength: 72,
          class: "w-full px-3 py-2 border border-stone-300 rounded-md text-sm text-stone-900 bg-white focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/15 transition" %>
  </div>
  <div class="mb-6">
    <%= f.label :password_confirmation, "Confirm password", class: "block text-xs font-semibold uppercase tracking-[0.05em] text-stone-600 mb-1.5" %>
    <%= f.password_field :password_confirmation,
          required: true,
          autocomplete: "new-password",
          placeholder: "••••••••",
          maxlength: 72,
          class: "w-full px-3 py-2 border border-stone-300 rounded-md text-sm text-stone-900 bg-white focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/15 transition" %>
  </div>
  <%= f.submit "Save password", class: "w-full px-4 py-2 bg-accent text-white rounded-md text-sm font-medium cursor-pointer border-none hover:bg-[#D4631E] transition" %>
<% end %>
