<%# locals: (item:) %>
<% if item.camera_model.present? %>
  <dl class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-muted mt-2">
    <div class="flex gap-1"><dt class="font-semibold">Camera</dt><dd><%= "#{item.camera_make} #{item.camera_model}".strip %></dd></div>
    <% if item.lens %>
      <div class="flex gap-1"><dt class="font-semibold">Lens</dt><dd><%= item.lens %></dd></div>
    <% end %>
    <% if item.focal_length %>
      <div class="flex gap-1"><dt class="font-semibold">FL</dt><dd><%= item.focal_length %></dd></div>
    <% end %>
    <% if item.aperture %>
      <div class="flex gap-1"><dt class="font-semibold">Aperture</dt><dd><%= item.aperture %></dd></div>
    <% end %>
    <% if item.shutter_speed %>
      <div class="flex gap-1"><dt class="font-semibold">Shutter</dt><dd><%= item.shutter_speed %></dd></div>
    <% end %>
    <% if item.iso %>
      <div class="flex gap-1"><dt class="font-semibold">ISO</dt><dd><%= item.iso %></dd></div>
    <% end %>
    <% if item.taken_at %>
      <div class="flex gap-1"><dt class="font-semibold">Date</dt><dd><%= item.taken_at.strftime("%-d %b %Y") %></dd></div>
    <% end %>
  </dl>
<% end %>
