<!DOCTYPE html>
<html>
  <head>
    <title>Sign in — Fieldnotes</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-[#F5F4F2] flex items-center justify-center min-h-screen">
    <main class="w-full px-6">
      <%= render "shared/flash" %>
      <div class="bg-white rounded-xl shadow-lg p-8 w-full max-w-sm mx-auto">
        <%= yield %>
      </div>
    </main>
  </body>
</html>
